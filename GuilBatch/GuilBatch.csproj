<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
	</PropertyGroup>

	<ItemGroup>
	  <Compile Remove="RectangleF.cs" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="MonoGame.Framework.DesktopGL" Version="3.8.4.1" />
	</ItemGroup>

	<ItemGroup>
		<UpToDateCheckInput Include="guilbatch-effect.fx" />
	</ItemGroup>

	<ItemGroup>
		<EmbeddedResource Include="guilbatch-effect.mgfx">
			<LogicalName>GuilBatch.guilbatch-effect.mgfx</LogicalName>
		</EmbeddedResource>
	</ItemGroup>

	<ItemGroup>
	  <ProjectReference Include="..\..\RectangleF\RectangleF.csproj" />
	</ItemGroup>

	<Target Name="CompileShaders" BeforeTargets="BeforeBuild" Inputs="guilbatch-effect.fx" Outputs="guilbatch-effect.mgfx">
		<Message Importance="High" Text="&gt; Compiling GuilBatch Shader..." />
		<Exec Command="dotnet tool run mgfxc guilbatch-effect.fx guilbatch-effect.mgfx /Profile:OpenGL" />
	</Target>

</Project>